{
	"name": "df_ventas_lpz_bronze_silver",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ventas_lpz_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ventas_sc_limpia_csv",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "estandarizarNomColumnas"
				},
				{
					"name": "eliminarEspVacios"
				},
				{
					"name": "estandarizarSucursal"
				},
				{
					"name": "estandarizarFecha"
				},
				{
					"name": "estandCantPrecio"
				},
				{
					"name": "reempMayusc"
				},
				{
					"name": "filtrarNulos"
				}
			],
			"scriptLines": [
				"source(output(",
				"          ID_Venta as string,",
				"          Fecha_Venta as string,",
				"          Producto as string,",
				"          Cant as string,",
				"          PrecioUnit as string,",
				"          Sucursal as string,",
				"          Vendedor as string,",
				"          NombreCliente as string,",
				"          EmailCliente as string,",
				"          MetodoPago as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 select(mapColumn(",
				"          id_venta = ID_Venta,",
				"          fecha = Fecha_Venta,",
				"          producto = Producto,",
				"          cantidad = Cant,",
				"          precio_unitario = PrecioUnit,",
				"          sucursal = Sucursal,",
				"          vendedor = Vendedor,",
				"          cliente_nombre = NombreCliente,",
				"          cliente_email = EmailCliente,",
				"          metodo_pago = MetodoPago",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> estandarizarNomColumnas",
				"estandarizarNomColumnas derive(id_venta = trim(id_venta),",
				"          fecha = trim(fecha),",
				"          producto = trim(producto),",
				"          cantidad = trim(cantidad),",
				"          precio_unitario = trim(precio_unitario),",
				"          sucursal = trim(sucursal),",
				"          vendedor = trim(vendedor),",
				"          cliente_nombre = trim(cliente_nombre),",
				"          cliente_email = trim(cliente_email),",
				"          metodo_pago = trim(metodo_pago)) ~> eliminarEspVacios",
				"eliminarEspVacios derive(sucursal = iif(\r",
				"    in(['La Paz','la paz','LAPAZ','lapaz','LaPaz','LP','LPZ','L.P.','lp','lpz','LA PAZ','Lapaz','laPaz'], sucursal),'La Paz',sucursal\r",
				"),",
				"          canal = 'Sucursal') ~> estandarizarSucursal",
				"estandarizarSucursal derive(fecha = coalesce(\r",
				"toDate(fecha,'yyyy-MM-dd'),\r",
				"toDate(fecha,'dd-MM-yyyy'),\r",
				"toDate(fecha,'MM-dd-yyyy'),\r",
				"toDate(fecha,'dd/MM/yyyy'),\r",
				"toDate(fecha,'yyyy/MM/dd'),\r",
				"toDate(fecha,'dd/MMM/yyyy'),\r",
				"toDate(fecha,'dd-MMM-yyyy'),\r",
				"toDate(fecha,'MMM-dd-yyyy'),\r",
				"toDate(fecha,'MMM dd, yyyy')\r",
				")) ~> estandarizarFecha",
				"estandarizarFecha derive(cantidad = toInteger(cantidad),",
				"          precio_unitario = toFloat(regexReplace(toString(precio_unitario),'[^0-9.]',''))) ~> estandCantPrecio",
				"estandCantPrecio derive(producto = initCap(regexReplace(producto,'\\\\s+',' '))) ~> reempMayusc",
				"reempMayusc filter(cantidad>0 && !isNull(precio_unitario) && !isNull(fecha)) ~> filtrarNulos",
				"filtrarNulos sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['ventas_lpz_limpio,csv'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1"
			]
		}
	}
}